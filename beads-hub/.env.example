# ═══════════════════════════════════════════
# Beads Agent Hub — Environment Configuration
# ═══════════════════════════════════════════
# Copy to .env and fill in values.
# For production: encrypt this file with SOPS/age instead.

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (optional — defaults to claude-sonnet-4-6)
# Other options: claude-opus-4-7 (most capable, ~5x cost), claude-haiku-4-5-20251001 (cheapest, fastest)
# CLAUDE_MODEL=claude-sonnet-4-6

# Server
PORT=3000
HOST=0.0.0.0

# Database (SQLite)
DB_PATH=./data/hub.db

# Beads project directory
BEADS_PROJECT_DIR=./beads-project

# Default admin password (only used on first run to create the admin user)
DEFAULT_PASSWORD=changeme

# Session secret (change this to a random string)
SESSION_SECRET=change-me-to-something-random

# Google OAuth 2.0 (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# HTTPS (set to true if behind a TLS-terminating proxy)
# USE_HTTPS=true
